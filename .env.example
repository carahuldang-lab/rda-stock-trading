# --- DHAN BROKER API ---
# Sign up at https://dhan.co/, get from https://dhan.co/profile/api-access
DHAN_CLIENT_ID=your_dhan_client_id_here
DHAN_ACCESS_TOKEN=your_dhan_access_token_here

# Trading mode: PAPER or LIVE
TRADING_MODE=PAPER

# --- TELEGRAM NOTIFICATIONS ---
# Reuse the bot you set up for RDA posts, or create a new one for trading alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- DATABASE (Phase 2 — leave blank for Phase 1) ---
DATABASE_URL=sqlite:///data/trading.db
# Phase 2 example: postgresql://user:pass@oracle-vps-ip:5432/trading

# --- ENVIRONMENT ---
ENVIRONMENT=development           # development | staging | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR

# --- OPTIONAL DATA SOURCES ---
# News / fundamentals (only if you upgrade later)
ALPHA_VANTAGE_API_KEY=
NEWS_API_KEY=
